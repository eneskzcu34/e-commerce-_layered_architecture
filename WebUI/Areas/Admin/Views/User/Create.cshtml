@using Application.DTOs.UserDTOs
@model UserCreateDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="form-title d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Ürün Ekle</h5>
</div>

<form asp-controller="User" asp-action="Create" method="post" class="mt-4">
    <div class="row g-3">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="col-md-6">
            <label class="form-label">Kullanıcı Adı</label>
            <input type="text" class="form-control" placeholder="Kullanıcı adı girin" asp-for="FirstName">
        </div>

         <div class="col-md-6">
            <label class="form-label">Kullanıcı Soyadı</label>
            <input type="text" class="form-control" placeholder="Kullanıcı Soyadı girin" asp-for="LastName">
        </div>

         <div class="col-md-6">
            <label class="form-label">Hesap Adı</label>
            <input type="text" class="form-control" placeholder="Hesap adı girin" asp-for="UserName">
        </div>
         <div class="col-md-6">
            <label class="form-label">E-Mail</label>
            <input type="text" class="form-control" placeholder="E-Mail girin" asp-for="EMail">
        </div>
         <div class="col-md-6">
            <label class="form-label">Parola</label>
            <input type="text" class="form-control" placeholder="Parola girin" asp-for="Password">
        </div> <div class="col-md-6">
            <label class="form-label">Parola Tekrar</label>
            <input type="text" class="form-control" placeholder="Parola tekrar girin" asp-for="ConfirmPassword">
        </div>
        <div class="col-md-6">
            <label class="form-label">Roller</label>
            <select class="form-select" asp-for="RoleId" asp-items="Model.SelectLists">
                <option value="">Seçiniz</option>
            </select>
        </div> 
        @* <div class="col-10">
            <label class="form-label">Açıklama</label>
            <textarea class="form-control" rows="4" placeholder="Ürün açıklaması..." asp-for="Description"></textarea>
        </div> *@
      @* <div class="col-2 p-4" style="text-align: center;">
            <label class="image-upload-box">
                <i class="bi bi-cloud-upload fs-3"></i>
                <div>Resim seç</div>
                <input type="file" class="d-none" asp-for="Images" multiple />
            </label>
        </div> *@
        <div class="col-12 d-flex justify-content-end gap-2 mt-3">
            <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="User">
                <i class="bi bi-x"></i> İptal
            </a>
            <button class="btn btn-primary">
                <i class="bi bi-check2"></i> Kaydet
            </button>
        </div>

    </div>
</form>