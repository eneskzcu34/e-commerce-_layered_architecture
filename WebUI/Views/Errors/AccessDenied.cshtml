@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>403 - Yetkisiz Erişim</title>

    <style>
        .error-page-card{
            text-align: center;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .error-page-title{
            font-size: 80px;
            color: #ff6b6b;
        }

        .error-page-subtitle{
            margin: 10px 0;
            color: #333;
        }

        .error-page-text{
            color: #666;
            margin-bottom: 20px;
        }

        .error-page-button{
            display: inline-block;
            text-decoration: none;
            background: #007bff;
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            transition: 0.3s;
        }

        .error-page-button:hover{
            background: #0056b3;
        }

    </style>
</head>

<body class="error-page-body">

    <div class="error-page-card">
        <h1 class="error-page-title">403</h1>

        <h2 class="error-page-subtitle">
            Yetkisiz Erişim
        </h2>

        <p class="error-page-text">
            Bu sayfaya erişim yetkiniz bulunmamaktadır.
        </p>

        <a href="/" class="error-page-button">
            Ana Sayfaya Dön
        </a>
    </div>

</body>
</html>