@using Application.DTOs.CartDTOs
@model CartDto
<div class="container mt-4">
    <div class="row g-4">
        <div class="col-md-8">
            <div class="ec-cart-table">
                <div class="ec-cart-head">
                    <div>Ürün</div>
                    <div>Fiyat</div>
                    <div>Adet</div>
                    <div>Toplam</div>
                    @* <div>İşlem</div> *@
                    <form asp-controller="Cart" asp-action="ClearCart" method="post">
                        <button type="submit" class="ec-clear-btn">Tümünü Sil
                        </button>
                    </form>
                </div>
                @foreach (var item in Model.Items)
                {
                    <div class="ec-cart-row">
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId"
                               class="ec-product-link">
                            <div class="ec-product">
                                <img src="@item.ImageUrl" alt="@item.ProductName" class="e  c-product-img">
                                <span>@item.ProductName</span>
                            </div>
                        </a>
                        <div class="ec-price">@item.UnitPrice TL</div>
                        <div class="ec-qty">
                            <button>-</button>
                            <input type="text" value="@item.Quantity" readonly>
                            <button>+</button>
                        </div>
                        <div class="ec-total">@item.TotalPrice TL</div>
                        <form asp-action="RemoveFromCart" method="post" asp-route-id="@item.Id" class="ec-remove-form">
                            <button type="submit" class="ec-remove-btn">✕</button>
                        </form>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-4">
            <div class="ec-summary-card">
                <h5>Sipariş Özeti</h5>
                <div class="ec-summary-row">
                    <span>Ara Toplam</span>
                    <span>@Model.TotalPrice.ToString("N2") TL</span>
                </div>
                <div class="ec-summary-row">
                    <span>Kargo</span>
                    <span class="text-success">Ücretsiz</span>
                </div>
                <hr>
                <div class="ec-summary-total">
                    <span>Toplam</span>
                    <span>@Model.TotalPrice.ToString("N2") TL</span>
                </div>
                <button class="ec-checkout">Ödemeye Geç</button>
            </div>
        </div>
    </div>
</div>