@using Application.DTOs.AdvertisementDTOs

@model List<AdvertisementsViewDto>
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between mb-3">
    <h5>Reklamlar</h5>
    <a asp-controller="Advertisement" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus"></i> Yeni Reklam
    </a>
</div>
<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Başlık</th>
            <th>Açıklama</th>
            <th>Resim</th>
            <th>Ürün Adı</th>
            <th>Ürün Kodu</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td><img src="@item.ImageUrl" alt="@item.Title" class="img-fluid" style="max-height: 100px;" /></td>
                <td>@item.ProductName</td>
                <td>@item.ProductCode</td>
                <td>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button class="btn btn-sm btn-danger" type="submit">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
